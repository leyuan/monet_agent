# ─────────────────────────────────────────────────────────────
# REQUIRED — agent will not start (or chat won't work) without these
# ─────────────────────────────────────────────────────────────

# LLM (read implicitly by langchain_anthropic)
ANTHROPIC_API_KEY=
# Claude model id (optional — default: anthropic:claude-sonnet-4-5-20250929)
MODEL_NAME=anthropic:claude-sonnet-4-5-20250929

# Supabase — memory, journal, trades, watchlist, risk settings
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Alpaca paper trading — quotes, portfolio, order placement
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# (SDK uses paper=True; ALPACA_BASE_URL is not currently read by the agent)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─────────────────────────────────────────────────────────────
# OPTIONAL — have safe defaults, fine to leave unset
# ─────────────────────────────────────────────────────────────

# Auth mode. "dev" = no-auth local access (LangGraph Studio / local chat).
# Set to anything else to enforce Supabase JWT validation. (default: dev)
LANGGRAPH_ENV=dev

# ─────────────────────────────────────────────────────────────
# OPTIONAL TOOLS — missing key only disables that tool (fails when invoked)
# ─────────────────────────────────────────────────────────────

# Tavily — chat web-search tool (news, qualitative research). https://tavily.com
TAVILY_API_KEY=

# Finnhub — earnings / fundamentals data tools. https://finnhub.io
FINNHUB_API_KEY=

# ─────────────────────────────────────────────────────────────
# AUTONOMOUS LOOP & EMAIL RECAP — only needed for cron / EOD email
# (not required for local chat testing)
# ─────────────────────────────────────────────────────────────

# Resend — sends the daily EOD recap email
RESEND_API_KEY=
DAILY_RECAP_FROM_EMAIL=

# Recipient/owner the recap is addressed to (default: built-in owner id)
RECAP_OWNER_ID=

# Base URL used for dashboard links in emails (default: https://monet.app)
NEXT_APP_URL=

# Deployed LangGraph Platform URL the recap trigger posts to.
# (optional — code defaults to the Monet production deployment URL if unset)
LANGGRAPH_URL=https://your-deployment.us.langgraph.app

# Triggering the deployed autonomous loop / sending messages to it.
# Falls back to LANGSMITH_API_KEY if unset.
LANGGRAPH_API_KEY=

# ─────────────────────────────────────────────────────────────
# OBSERVABILITY — LangSmith tracing (optional)
# ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=monet

# ─────────────────────────────────────────────────────────────
# SCHEDULER — crons are managed via the LangGraph SDK (create_crons.py);
# this var is not currently read by the agent code.
# ─────────────────────────────────────────────────────────────
AUTONOMOUS_LOOP_CRON=0 9,13,16 * * 1-5
