# ─────────────────────────────────────────────────────────────
# Supabase — auth + reads dashboard/journal/trades data
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* are exposed to the browser; the service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# LangGraph — backend the chat UI streams from
# ─────────────────────────────────────────────────────────────
# Local agent (langgraph dev). Deployed: the platform URL.
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=monet_agent

# ─────────────────────────────────────────────────────────────
# Alpaca paper trading — used by /api/portfolio and /api/performance
# ─────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─────────────────────────────────────────────────────────────
# App URL — used for unsubscribe + email-render links
# (default in code: https://monet.app)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Anthropic — used by /api/generate-title to name chat threads.
# Read implicitly by the @anthropic-ai/sdk client (new Anthropic()).
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
